<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#070F1E">

    <!-- Invisible Toolbar so ToolbarFragment doesn't crash -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- SERVER-DRIVEN header: avatar + email + status card  -->
            <!-- Edit design → app_profile.php on server            -->
            <!-- ═══════════════════════════════════════════════════ -->
            <WebView
                android:id="@+id/webview_profile_header"
                android:layout_width="match_parent"
                android:layout_height="215dp"
                android:background="#070F1E" />

            <!-- ╔═══════════════════════════════════════════╗ -->
            <!-- ║  СЕКЦИЯ: АККАУНТ                         ║ -->
            <!-- ╚═══════════════════════════════════════════╝ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="АККАУНТ"
                android:textColor="#2A3D58"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_glass_card"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <!-- Подписка ──────────────────────────────── -->
                <LinearLayout
                    android:id="@+id/item_subscription"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <!-- Иконка: синяя -->
                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_badge_trial"
                        android:backgroundTint="#1A3B82F6">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_action_done"
                            app:tint="#3B82F6" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Подписка"
                            android:textColor="#E2E8F0"
                            android:textSize="15sp" />
                        <TextView
                            android:id="@+id/tv_sub_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Управление и оплата"
                            android:textColor="#3B4F6B"
                            android:textSize="12sp"
                            android:layout_marginTop="1dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#2A3D58" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#0C1A2E"
                    android:layout_marginStart="64dp"
                    android:layout_marginEnd="14dp" />

                <!-- Привилегии ─────────────────────────────── -->
                <LinearLayout
                    android:id="@+id/item_privileges"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <!-- Иконка: фиолетовая -->
                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_badge_trial"
                        android:backgroundTint="#1A8B5CF6">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_baseline_card_giftcard_24"
                            app:tint="#8B5CF6" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Привилегии"
                            android:textColor="#E2E8F0"
                            android:textSize="15sp" />
                        <TextView
                            android:id="@+id/tv_privileges_subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Промокоды и приглашения"
                            android:textColor="#3B4F6B"
                            android:textSize="12sp"
                            android:layout_marginTop="1dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#2A3D58" />
                </LinearLayout>

            </LinearLayout>

            <!-- ╔═══════════════════════════════════════════╗ -->
            <!-- ║  СЕКЦИЯ: ПОДКЛЮЧЕНИЕ                     ║ -->
            <!-- ╚═══════════════════════════════════════════╝ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ПОДКЛЮЧЕНИЕ"
                android:textColor="#2A3D58"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_glass_card"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <!-- Обновить подключение ──────────────────── -->
                <LinearLayout
                    android:id="@+id/item_refresh"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <!-- Иконка: зелёная -->
                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_badge_trial"
                        android:backgroundTint="#1A10B981">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_baseline_refresh_24"
                            app:tint="#10B981" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp"
                        android:text="Обновить подключение"
                        android:textColor="#E2E8F0"
                        android:textSize="15sp" />

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#2A3D58" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#0C1A2E"
                    android:layout_marginStart="64dp"
                    android:layout_marginEnd="14dp" />

                <!-- Мои устройства ─────────────────────────── -->
                <LinearLayout
                    android:id="@+id/item_devices"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <!-- Иконка: голубая -->
                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_badge_trial"
                        android:backgroundTint="#1A25C9EF">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_devices"
                            app:tint="#25C9EF" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp"
                        android:text="Мои устройства"
                        android:textColor="#E2E8F0"
                        android:textSize="15sp" />

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#2A3D58" />
                </LinearLayout>

            </LinearLayout>

            <!-- ╔═══════════════════════════════════════════╗ -->
            <!-- ║  СЕКЦИЯ: ПРОЧЕЕ                          ║ -->
            <!-- ╚═══════════════════════════════════════════╝ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ПРОЧЕЕ"
                android:textColor="#2A3D58"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_glass_card"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <!-- Поддержка ──────────────────────────────── -->
                <LinearLayout
                    android:id="@+id/item_support"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <!-- Иконка: оранжевая -->
                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_badge_trial"
                        android:backgroundTint="#1AF59E0B">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_help_outline"
                            app:tint="#F59E0B" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp"
                        android:text="Поддержка"
                        android:textColor="#E2E8F0"
                        android:textSize="15sp" />

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#2A3D58" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#0C1A2E"
                    android:layout_marginStart="64dp"
                    android:layout_marginEnd="14dp" />

                <!-- Настройки ──────────────────────────────── -->
                <LinearLayout
                    android:id="@+id/item_settings"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <!-- Иконка: серая -->
                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_badge_trial"
                        android:backgroundTint="#1464748B">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_action_settings"
                            app:tint="#94A3B8" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp"
                        android:text="Настройки"
                        android:textColor="#E2E8F0"
                        android:textSize="15sp" />

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#2A3D58" />
                </LinearLayout>

            </LinearLayout>

            <!-- ── Выход ─────────────────────────────────────── -->
            <TextView
                android:id="@+id/item_logout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:padding="14dp"
                android:text="Выйти из аккаунта"
                android:textColor="#2A3D58"
                android:textSize="14sp"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <!-- ── Версия + обновление ───────────────────────── -->
            <TextView
                android:id="@+id/tv_version"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="LvovFlow v1.0.0"
                android:textColor="#1A2E45"
                android:textSize="12sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/tv_check_update"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="2dp"
                android:padding="8dp"
                android:text="Проверить обновления"
                android:textColor="#25C9EF"
                android:textSize="12sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
