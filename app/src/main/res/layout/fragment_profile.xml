<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#0B0E14">

    <!-- Invisible Toolbar so ToolbarFragment doesn't crash -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="90dp">

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- PROFILE HEADER: Avatar + Name + Email + ID         -->
            <!-- ═══════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="24dp"
                android:paddingBottom="20dp">

                <!-- Avatar circle with gradient border -->
                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp">
                    <View
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_avatar_gradient_border" />
                    <TextView
                        android:id="@+id/tv_avatar_letter"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="И"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />
                </FrameLayout>

                <!-- User info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:id="@+id/tv_user_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Пользователь"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_user_email"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="user@example.com"
                        android:textColor="#8B949E"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_user_id"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:background="@drawable/bg_user_id_badge"
                        android:text="ID: 0000-XXX"
                        android:textColor="#00F0FF"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.08" />
                </LinearLayout>
            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- STATS ROW: Downloaded / Uploaded                   -->
            <!-- ═══════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="16dp">

                <!-- Download stat card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_stat_card"
                    android:padding="10dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Arrow down icon -->
                    <FrameLayout
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_badge_trial"
                        android:backgroundTint="#1A00F0FF">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_arrow_down"
                            app:tint="#00F0FF" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginStart="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Скачано"
                            android:textColor="#8B949E"
                            android:textSize="12sp"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:id="@+id/tv_stat_download"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 Б"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Upload stat card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_stat_card"
                    android:padding="10dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Arrow up icon -->
                    <FrameLayout
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_badge_trial"
                        android:backgroundTint="#1A00E676">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_arrow_up"
                            app:tint="#00E676" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginStart="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Отдано"
                            android:textColor="#8B949E"
                            android:textSize="12sp"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:id="@+id/tv_stat_upload"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 Б"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- SETTINGS GROUP 1: Account                          -->
            <!-- ═══════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_settings_group_concept">

                <!-- Подписка -->
                <LinearLayout
                    android:id="@+id/item_subscription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <FrameLayout
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_settings_icon_concept">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_action_done"
                            app:tint="#8B949E" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Подписка"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_sub_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Активна"
                        android:textColor="#00E676"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#8B949E"
                        android:textSize="18sp" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#0DFFFFFF"
                    android:layout_marginStart="58dp"
                    android:layout_marginEnd="16dp" />

                <!-- Привилегии -->
                <LinearLayout
                    android:id="@+id/item_privileges"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <FrameLayout
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_settings_icon_concept">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_baseline_card_giftcard_24"
                            app:tint="#8B949E" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Привилегии"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#8B949E"
                        android:textSize="18sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- SETTINGS GROUP 2: App                              -->
            <!-- ═══════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_settings_group_concept">

                <!-- Мои устройства -->
                <LinearLayout
                    android:id="@+id/item_devices"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <FrameLayout
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_settings_icon_concept">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_devices"
                            app:tint="#8B949E" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Мои устройства"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_devices_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1/5"
                        android:textColor="#8B949E"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#8B949E"
                        android:textSize="18sp" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#0DFFFFFF"
                    android:layout_marginStart="58dp"
                    android:layout_marginEnd="16dp" />

                <!-- Обновить подключение -->
                <LinearLayout
                    android:id="@+id/item_refresh"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <FrameLayout
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_settings_icon_concept">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_baseline_refresh_24"
                            app:tint="#8B949E" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Обновить подключение"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#8B949E"
                        android:textSize="18sp" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#0DFFFFFF"
                    android:layout_marginStart="58dp"
                    android:layout_marginEnd="16dp" />

                <!-- Поддержка -->
                <LinearLayout
                    android:id="@+id/item_support"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <FrameLayout
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_settings_icon_concept">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_help_outline"
                            app:tint="#8B949E" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Поддержка"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#8B949E"
                        android:textSize="18sp" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#0DFFFFFF"
                    android:layout_marginStart="58dp"
                    android:layout_marginEnd="16dp" />

                <!-- Настройки -->
                <LinearLayout
                    android:id="@+id/item_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <FrameLayout
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_settings_icon_concept">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_action_settings"
                            app:tint="#8B949E" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Настройки"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#8B949E"
                        android:textSize="18sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- LOGOUT BUTTON                                      -->
            <!-- ═══════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/item_logout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_logout_btn_concept"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_baseline_logout_24"
                    app:tint="#FF5252" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Выйти из аккаунта"
                    android:textColor="#FF5252"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ── Версия + обновление ───────────────────────── -->
            <TextView
                android:id="@+id/tv_version"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="LvovFlow v1.0.0"
                android:textColor="#4A5568"
                android:textSize="12sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/tv_check_update"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="2dp"
                android:padding="8dp"
                android:text="Проверить обновления"
                android:textColor="#00F0FF"
                android:textSize="12sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
