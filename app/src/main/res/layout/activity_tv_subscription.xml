<?xml version="1.0" encoding="utf-8"?>
<!-- LvovFlow — TV Subscription Layout (landscape, compact, with QR payment) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#0A1628"
    android:paddingStart="48dp"
    android:paddingEnd="48dp"
    android:paddingTop="27dp"
    android:paddingBottom="27dp"
    android:baselineAligned="false">

    <!-- ════════════════════════════════════════════ -->
    <!-- LEFT PANEL — Status + Features               -->
    <!-- ════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingEnd="24dp"
        android:gravity="center_vertical">

        <!-- Header with back -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <ImageButton
                android:id="@+id/tv_sub_btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/baseline_arrow_back_24"
                android:padding="8dp"
                android:focusable="true"
                android:contentDescription="Назад"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Моя подписка"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Status card (compact) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:elevation="4dp">

            <!-- Plan + days column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_plan_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Flow"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <!-- Status badge -->
                    <LinearLayout
                        android:id="@+id/badge_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_pill_badge"
                        android:backgroundTint="#1A22C55E"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="8dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp">

                        <View
                            android:id="@+id/dot_status"
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:layout_marginEnd="5dp"
                            android:background="@drawable/bg_circle_green" />

                        <TextView
                            android:id="@+id/tv_status_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Активна"
                            android:textColor="#22C55E"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Expire date -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ic_clock"
                        app:tint="#64748B" />

                    <TextView
                        android:id="@+id/tv_expire_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Действует до 26.07.2026"
                        android:textColor="#94A3B8"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Days big number -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_days_left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:text="117" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="дней"
                    android:textColor="#64748B"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Features (compact row) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_glass_card"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center"
            android:elevation="4dp">

            <!-- Feature 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_tariff_rocket"
                    app:tint="#10B981" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Безлимит"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:background="#15FFFFFF" />

            <!-- Feature 2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_tariff_shield"
                    app:tint="#10B981" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Без рекламы"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:background="#15FFFFFF" />

            <!-- Feature 3 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_tariff_devices"
                    app:tint="#10B981" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="2 устройства"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ════════════════════════════════════════════ -->
    <!-- RIGHT PANEL — QR Payment                     -->
    <!-- ════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:gravity="center">

        <!-- QR Card -->
        <LinearLayout
            android:id="@+id/tv_qr_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Продлить подписку"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Отсканируйте QR-код телефоном"
                android:textColor="#64748B"
                android:textSize="13sp" />

            <!-- QR code image -->
            <ImageView
                android:id="@+id/tv_qr_image"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:background="#FFFFFF"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:contentDescription="QR-код оплаты" />

            <!-- Loading indicator (visible while creating payment) -->
            <ProgressBar
                android:id="@+id/tv_qr_loading"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:indeterminateTint="#25C9EF"
                android:visibility="visible" />

            <!-- Error text (hidden by default) -->
            <TextView
                android:id="@+id/tv_qr_error"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Не удалось создать платёж"
                android:textColor="#EF4444"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- Price -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="99 ₽ / месяц"
                android:textColor="#10B981"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Renew button (focusable for D-Pad, regenerates QR) -->
            <Button
                android:id="@+id/btn_renew"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="#10B981"
                android:text="Обновить QR-код"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:focusable="true"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
