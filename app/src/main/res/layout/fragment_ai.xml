<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0E14">

    <!-- Glow halo behind icon -->
    <View
        android:id="@+id/ai_glow"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:alpha="0.15"
        android:background="@drawable/bg_circle_green"
        android:backgroundTint="#00F0FF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.28" />

    <!-- Stars Icon — 84dp matching concept -->
    <ImageView
        android:id="@+id/ai_icon"
        android:layout_width="84dp"
        android:layout_height="84dp"
        android:src="@drawable/ic_ai_stars"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.30" />

    <!-- Title: LvovFlow AI -->
    <TextView
        android:id="@+id/ai_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="LvovFlow AI"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toBottomOf="@id/ai_icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subtitle: Скоро -->
    <TextView
        android:id="@+id/ai_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Скоро"
        android:textColor="#00F0FF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.15"
        app:layout_constraintTop_toBottomOf="@id/ai_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Description -->
    <TextView
        android:id="@+id/ai_description"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Все нейросети в одном месте. Gemini, ChatGPT, Claude и другие — общайся с лучшими ИИ напрямую из приложения без ограничений."
        android:textColor="#8B949E"
        android:textSize="16sp"
        android:textAlignment="center"
        android:lineSpacingExtra="4dp"
        app:layout_constraintTop_toBottomOf="@id/ai_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Loading dots: dim - bright - dim -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/ai_description"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/dot_1"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_circle_green"
            android:backgroundTint="#00F0FF"
            android:alpha="0.2" />

        <View
            android:id="@+id/dot_2"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_circle_green"
            android:backgroundTint="#00F0FF"
            android:alpha="1.0" />

        <View
            android:id="@+id/dot_3"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_circle_green"
            android:backgroundTint="#00F0FF"
            android:alpha="0.2" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
