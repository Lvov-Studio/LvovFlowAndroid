<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0B0E14"
    android:fitsSystemWindows="true">

    <!-- AppBar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_settings_icon_concept"
            android:src="@drawable/baseline_arrow_back_24"
            android:padding="8dp"
            android:contentDescription="Назад"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Мои устройства"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:scrollbars="none"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══════════════════════════════════════ -->
            <!-- TOP ACTIONS GRID (2 cards)             -->
            <!-- ══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <!-- QR Login card -->
                <LinearLayout
                    android:id="@+id/card_qr_login"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_device_action_cyan"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center_horizontal"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_marginBottom="8dp"
                        android:src="@drawable/ic_qr_code"
                        app:tint="#00F0FF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Войти по QR"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Отсканируйте код\nна ТВ или ПК"
                        android:textColor="#8B949E"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:lineSpacingExtra="2dp" />
                </LinearLayout>

                <!-- Sub Key card -->
                <LinearLayout
                    android:id="@+id/card_sub_key"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_device_action_green"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center_horizontal"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_marginBottom="8dp"
                        android:src="@drawable/ic_vpn_key"
                        app:tint="#00E676" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ключ подписки"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Для настройки на\nроутерах и ПК"
                        android:textColor="#8B949E"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:lineSpacingExtra="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Key details (expandable, hidden by default) -->
            <LinearLayout
                android:id="@+id/key_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_settings_group_concept"
                android:padding="16dp">

                <!-- Sub URL -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_referral_field_concept"
                    android:padding="12dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_sub_url"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="https://..."
                        android:textColor="#8B949E"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:maxLines="2"
                        android:ellipsize="middle" />

                    <ImageButton
                        android:id="@+id/btn_copy_url"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_baseline_content_copy_24"
                        android:padding="6dp"
                        android:contentDescription="Копировать"
                        app:tint="#00F0FF" />
                </LinearLayout>

                <!-- QR of subscription URL -->
                <ImageView
                    android:id="@+id/iv_sub_qr"
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:background="#FFFFFF"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:contentDescription="QR ключа подписки" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Отсканируйте в V2rayN, Nekoray или другом клиенте"
                    android:textColor="#4A5568"
                    android:textSize="12sp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- ══════════════════════════════════════ -->
            <!-- ACTIVE SESSIONS                        -->
            <!-- ══════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:text="АКТИВНЫЕ СЕССИИ"
                android:textColor="#8B949E"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <LinearLayout
                android:id="@+id/sessions_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Sessions loaded dynamically -->
                <LinearLayout
                    android:id="@+id/sessions_loading"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_settings_group_concept"
                    android:padding="16dp">
                    <ProgressBar
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:indeterminateTint="#00F0FF" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Загрузка..."
                        android:textColor="#8B949E"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Session list (filled programmatically) -->
                <LinearLayout
                    android:id="@+id/sessions_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone" />

                <!-- Error -->
                <TextView
                    android:id="@+id/sessions_error"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center"
                    android:text="Не удалось загрузить"
                    android:textColor="#EF4444"
                    android:textSize="14sp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Terminate all button -->
            <TextView
                android:id="@+id/btn_terminate_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                android:padding="12dp"
                android:text="Завершить все другие сессии"
                android:textColor="#FF5252"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
