<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#99000000">

    <!-- Centered card -->
    <LinearLayout
        android:layout_width="420dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@drawable/bg_glass_card"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <!-- Glow accent line at top -->
        <View
            android:layout_width="60dp"
            android:layout_height="3dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_gradient_cyan" />

        <!-- Update icon -->
        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_baseline_update_24"
            app:tint="#22D3EE"
            android:layout_marginBottom="16dp" />

        <!-- Title -->
        <TextView
            android:id="@+id/tv_update_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Обновление"
            android:textColor="#F8FAFC"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="4dp" />

        <!-- Version number -->
        <TextView
            android:id="@+id/tv_update_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0.4"
            android:textColor="#22D3EE"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Separator -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A3050"
            android:layout_marginBottom="16dp" />

        <!-- Changelog description -->
        <TextView
            android:id="@+id/tv_update_changelog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Оптимизация и стабильность."
            android:textColor="#94A3B8"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:gravity="center"
            android:layout_marginBottom="28dp" />

        <!-- Download progress (hidden by default) -->
        <LinearLayout
            android:id="@+id/tv_update_progress_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="gone"
            android:layout_marginBottom="16dp">

            <ProgressBar
                android:id="@+id/tv_update_progress_bar"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#22D3EE"
                android:progressBackgroundTint="#1A3050"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_update_progress_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Скачивание... 0%"
                android:textColor="#94A3B8"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Update button (D-pad focusable, gradient) -->
        <Button
            android:id="@+id/tv_btn_update_now"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_btn_update_tv"
            android:text="Обновить"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:focusable="true"
            android:layout_marginBottom="10dp"
            android:nextFocusDown="@+id/tv_btn_update_later" />

        <!-- Later button -->
        <Button
            android:id="@+id/tv_btn_update_later"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@android:color/transparent"
            android:text="Позже"
            android:textColor="#64748B"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:focusable="true"
            android:nextFocusUp="@id/tv_btn_update_now" />

    </LinearLayout>
</FrameLayout>
