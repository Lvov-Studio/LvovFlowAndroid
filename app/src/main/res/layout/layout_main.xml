<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:openDrawer="start">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/coordinator"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0A1628"
        android:clipChildren="false">

        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:id="@+id/fragment_holder"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/fabProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:max="1"
            android:visibility="invisible"
            app:indicatorColor="?colorMaterial100"
            app:layout_anchor="@+id/fab"
            app:layout_anchorGravity="center"
            app:layout_behavior="io.nekohasekai.sagernet.widget.FabProgressBehavior"
            app:trackCornerRadius="@dimen/mtrl_progress_track_thickness"
            app:trackThickness="8dp" />

        <!-- Background glow (changes color on connect) -->
        <View
            android:id="@+id/glow_bg"
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="128dp"
            android:background="@drawable/bg_glow_circle"
            android:alpha="0.45" />

        <!-- Pulse ring 1 (innermost) -->
        <View
            android:id="@+id/pulse_ring_1"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="214dp"
            android:background="@drawable/bg_pulse_ring"
            android:alpha="0" />

        <!-- Pulse ring 2 (middle) -->
        <View
            android:id="@+id/pulse_ring_2"
            android:layout_width="185dp"
            android:layout_height="185dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="191dp"
            android:background="@drawable/bg_pulse_ring"
            android:alpha="0" />

        <!-- Pulse ring 3 (outermost) -->
        <View
            android:id="@+id/pulse_ring_3"
            android:layout_width="230dp"
            android:layout_height="230dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="169dp"
            android:background="@drawable/bg_pulse_ring"
            android:alpha="0" />

        <!-- LvovFlow: Connection timer label -->
        <TextView
            android:id="@+id/conn_timer_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="120dp"
            android:text="Время подключения"
            android:textColor="?whiteOrTextPrimary"
            android:textSize="12sp"
            android:alpha="0.6"
            android:visibility="gone" />

        <!-- LvovFlow: Connection timer clock -->
        <TextView
            android:id="@+id/conn_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="138dp"
            android:text="00:00:00"
            android:textColor="?whiteOrTextPrimary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:visibility="gone" />

        <!-- FAB (connect button) -->
        <io.nekohasekai.sagernet.widget.ServiceButton
            android:id="@+id/fab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:elevation="12dp"
            android:nextFocusDown="@+id/stats"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="228dp"
            app:backgroundTint="?fabColorBackground"
            app:fabCustomSize="112dp"
            app:iconSize="84dp"
            app:pressedTranslationZ="6dp"
            app:srcCompat="@drawable/ic_service_idle" />

        <!-- Status text -->
        <TextView
            android:id="@+id/conn_status_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="352dp"
            android:text="Активировать ускорение"
            android:textColor="?whiteOrTextPrimary"
            android:textSize="15sp"
            android:alpha="0.85" />

        <!-- Server name label (shown when connected, now positioned under the button) -->
        <LinearLayout
            android:id="@+id/server_button_container"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="130dp"
            android:background="@drawable/bg_glass_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/conn_server_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Оптимальный сервер: 🇩🇪"
                android:textColor="#E2E8F0"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_chevron_right"
                android:tint="#64748B" />

        </LinearLayout>

    <!-- Removed legacy server info card and speed row for premium UI -->

        <!-- StatsBar (bottom) - hidden, speed shown in custom speed_row -->
    <!-- Removed StatsBar for premium UI -->

        <!-- Bottom Navigation Bar -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:elevation="16dp"
            android:paddingBottom="4dp"
            app:backgroundTint="#0D1626"
            app:itemIconTint="@color/bottom_nav_icon"
            app:itemTextColor="@color/bottom_nav_icon"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/bottom_nav_menu" />


    </androidx.coordinatorlayout.widget.CoordinatorLayout>


    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        style="@style/Widget.Design.NavigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/layout_nav_header"
        app:itemIconTint="@color/navigation_icon"
        app:itemTextColor="@color/navigation_icon"
        app:menu="@menu/main_drawer_menu" />

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view_black"
        style="@style/Widget.Design.NavigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/layout_nav_header"
        app:itemIconTint="@color/navigation_icon"
        app:itemShapeAppearance="@style/ShapeAppearance.MaterialComponents.MediumComponent"
        app:itemShapeFillColor="@color/navigation_item"
        app:itemTextColor="@color/navigation_icon"
        app:menu="@menu/main_drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>