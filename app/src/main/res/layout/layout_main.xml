<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:openDrawer="start">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/coordinator"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0A1628"
        android:clipChildren="false">

        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:id="@+id/fragment_holder"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Main Centered Container -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/main_home_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Timer Label -->
            <TextView
                android:id="@+id/conn_timer_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="2dp"
                android:text="Время подключения"
                android:textColor="#94A3B8"
                android:textSize="13sp"
                android:visibility="gone"
                app:layout_constraintBottom_toTopOf="@id/conn_timer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Timer Clock -->
            <TextView
                android:id="@+id/conn_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="00:00:00"
                android:textColor="#F8FAFC"
                android:textSize="36sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:visibility="gone"
                app:layout_constraintBottom_toTopOf="@id/speed_row"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Speed Row (download / upload) -->
            <LinearLayout
                android:id="@+id/speed_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:visibility="gone"
                app:layout_constraintBottom_toTopOf="@id/speed_sparkline"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/tv_speed_down"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↓ 0 Б/с"
                    android:textColor="#22C55E"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:background="#2E3A50" />

                <TextView
                    android:id="@+id/tv_speed_up"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↑ 0 Б/с"
                    android:textColor="#22D3EE"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

            <!-- Speed Sparkline Graph -->
            <io.nekohasekai.sagernet.widget.SpeedSparklineView
                android:id="@+id/speed_sparkline"
                android:layout_width="240dp"
                android:layout_height="40dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                app:layout_constraintBottom_toTopOf="@id/button_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Circular Button and Glows -->
            <FrameLayout
                android:id="@+id/button_container"
                android:layout_width="280dp"
                android:layout_height="280dp"
                android:clipChildren="false"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="0.47">

                <View
                    android:id="@+id/glow_bg"
                    android:layout_width="280dp"
                    android:layout_height="280dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_glow_circle"
                    android:alpha="0.45" />

                <View
                    android:id="@+id/pulse_ring_3"
                    android:layout_width="210dp"
                    android:layout_height="210dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_pulse_ring"
                    android:alpha="0" />

                <View
                    android:id="@+id/pulse_ring_2"
                    android:layout_width="170dp"
                    android:layout_height="170dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_pulse_ring"
                    android:alpha="0" />

                <View
                    android:id="@+id/pulse_ring_1"
                    android:layout_width="135dp"
                    android:layout_height="135dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_pulse_ring"
                    android:alpha="0" />

                <io.nekohasekai.sagernet.widget.ServiceButton
                    android:id="@+id/fab"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:elevation="12dp"
                    android:layout_gravity="center"
                    app:backgroundTint="?fabColorBackground"
                    app:fabCustomSize="112dp"
                    app:iconSize="56dp"
                    app:pressedTranslationZ="6dp"
                    app:srcCompat="@drawable/ic_service_idle" />

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/fabProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:max="1"
                    android:visibility="invisible"
                    app:indicatorColor="?colorMaterial100"
                    app:indicatorSize="120dp"
                    app:trackCornerRadius="@dimen/mtrl_progress_track_thickness"
                    app:trackThickness="8dp" />

                <!-- Shockwave rings for connection animation -->
                <View
                    android:id="@+id/shockwave_1"
                    android:layout_width="112dp"
                    android:layout_height="112dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_shockwave_ring"
                    android:alpha="0"
                    android:elevation="0dp" />

                <View
                    android:id="@+id/shockwave_2"
                    android:layout_width="112dp"
                    android:layout_height="112dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_shockwave_ring"
                    android:alpha="0"
                    android:elevation="0dp" />

            </FrameLayout>

            <!-- Status text -->
            <TextView
                android:id="@+id/conn_status_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Активировать ускорение"
                android:textColor="#E2E8F0"
                android:textSize="16sp"
                android:letterSpacing="0.02"
                app:layout_constraintTop_toBottomOf="@id/button_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- IP info (shown when connected) -->
            <TextView
                android:id="@+id/tv_ip_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text=""
                android:textColor="#64748B"
                android:textSize="12sp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/conn_status_label"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Server name label (shown when connected, now positioned under the button) -->
        <LinearLayout
            android:id="@+id/server_button_container"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="130dp"
            android:background="@drawable/bg_glass_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/conn_server_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Оптимальный сервер: 🇩🇪"
                android:textColor="#E2E8F0"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_chevron_right"
                android:tint="#64748B" />

        </LinearLayout>

    <!-- Removed legacy server info card and speed row for premium UI -->

        <!-- StatsBar (bottom) - hidden, speed shown in custom speed_row -->
    <!-- Removed StatsBar for premium UI -->

        <!-- Bottom Navigation Bar -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:elevation="16dp"
            android:paddingBottom="4dp"
            app:backgroundTint="#0D1626"
            app:itemIconTint="@color/bottom_nav_icon"
            app:itemTextColor="@color/bottom_nav_icon"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/bottom_nav_menu" />


    </androidx.coordinatorlayout.widget.CoordinatorLayout>


    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        style="@style/Widget.Design.NavigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/layout_nav_header"
        app:itemIconTint="@color/navigation_icon"
        app:itemTextColor="@color/navigation_icon"
        app:menu="@menu/main_drawer_menu" />

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view_black"
        style="@style/Widget.Design.NavigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/layout_nav_header"
        app:itemIconTint="@color/navigation_icon"
        app:itemShapeAppearance="@style/ShapeAppearance.MaterialComponents.MediumComponent"
        app:itemShapeFillColor="@color/navigation_item"
        app:itemTextColor="@color/navigation_icon"
        app:menu="@menu/main_drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>