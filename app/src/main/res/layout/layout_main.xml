<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:openDrawer="start">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/coordinator"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false">

        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:id="@+id/fragment_holder"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- We double trackThickness as half of it will be invisible -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/fabProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:max="1"
            android:visibility="invisible"
            app:indicatorColor="?colorMaterial100"
            app:layout_anchor="@+id/fab"
            app:layout_anchorGravity="center"
            app:layout_behavior="io.nekohasekai.sagernet.widget.FabProgressBehavior"
            app:trackCornerRadius="@dimen/mtrl_progress_track_thickness"
            app:trackThickness="8dp" />

        <!-- LvovFlow: Connection timer label (visible only when connected) -->
        <TextView
            android:id="@+id/conn_timer_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="64dp"
            android:text="Время подключения"
            android:textColor="?whiteOrTextPrimary"
            android:textSize="13sp"
            android:alpha="0.7"
            android:visibility="gone" />

        <!-- LvovFlow: Connection timer clock -->
        <TextView
            android:id="@+id/conn_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="82dp"
            android:text="00:00:00"
            android:textColor="?whiteOrTextPrimary"
            android:textSize="30sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:visibility="gone" />

        <io.nekohasekai.sagernet.widget.ServiceButton
            android:id="@+id/fab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:elevation="8dp"
            android:nextFocusDown="@+id/stats"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="172dp"
            app:backgroundTint="?fabColorBackground"
            app:fabCustomSize="112dp"
            app:iconSize="84dp"
            app:pressedTranslationZ="6dp"
            app:srcCompat="@drawable/ic_service_idle" />

        <!-- LvovFlow: Status text below FAB -->
        <TextView
            android:id="@+id/conn_status_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="294dp"
            android:text="Нажмите для подключения"
            android:textColor="?whiteOrTextPrimary"
            android:textSize="14sp"
            android:alpha="0.85" />

        <!-- LvovFlow: Active server name (shown only when connected) -->
        <TextView
            android:id="@+id/conn_server_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="316dp"
            android:text=""
            android:textColor="#25C9EF"
            android:textSize="12sp"
            android:alpha="0.9"
            android:visibility="gone" />

        <io.nekohasekai.sagernet.widget.StatsBar
            android:id="@+id/stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:nextFocusUp="@+id/fab"
            app:backgroundTint="?colorMaterial300"
            app:contentInsetStart="0dp"
            app:hideOnScroll="true"
            app:layout_scrollFlags="enterAlways|scroll">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Speed graph + compact TX/RX text side by side -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <io.nekohasekai.sagernet.widget.SpeedGraphView
                        android:id="@+id/speed_graph"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:id="@+id/tx"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="marquee"
                            android:singleLine="true"
                            android:textColor="?whiteOrTextPrimary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/rx"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="marquee"
                            android:singleLine="true"
                            android:textColor="?whiteOrTextPrimary"
                            android:textSize="12sp" />

                    </LinearLayout>

                </LinearLayout>

                <TextView
                    android:id="@+id/status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="fill_horizontal"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="?whiteOrTextPrimary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="@string/connection_test_available" />

            </LinearLayout>


        </io.nekohasekai.sagernet.widget.StatsBar>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        style="@style/Widget.Design.NavigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/layout_nav_header"
        app:itemIconTint="@color/navigation_icon"
        app:itemTextColor="@color/navigation_icon"
        app:menu="@menu/main_drawer_menu" />

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view_black"
        style="@style/Widget.Design.NavigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/layout_nav_header"
        app:itemIconTint="@color/navigation_icon"
        app:itemShapeAppearance="@style/ShapeAppearance.MaterialComponents.MediumComponent"
        app:itemShapeFillColor="@color/navigation_item"
        app:itemTextColor="@color/navigation_icon"
        app:menu="@menu/main_drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>