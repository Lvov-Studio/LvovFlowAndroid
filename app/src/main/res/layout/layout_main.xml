<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:openDrawer="start">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/coordinator"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0A1628"
        android:clipChildren="false">

        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:id="@+id/fragment_holder"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/fabProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:max="1"
            android:visibility="invisible"
            app:indicatorColor="?colorMaterial100"
            app:layout_anchor="@+id/fab"
            app:layout_anchorGravity="center"
            app:layout_behavior="io.nekohasekai.sagernet.widget.FabProgressBehavior"
            app:trackCornerRadius="@dimen/mtrl_progress_track_thickness"
            app:trackThickness="8dp" />

        <!-- Background glow (changes color on connect) -->
        <View
            android:id="@+id/glow_bg"
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="128dp"
            android:background="@drawable/bg_glow_circle"
            android:alpha="0.45" />

        <!-- Pulse ring 1 (innermost) -->
        <View
            android:id="@+id/pulse_ring_1"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="214dp"
            android:background="@drawable/bg_pulse_ring"
            android:alpha="0" />

        <!-- Pulse ring 2 (middle) -->
        <View
            android:id="@+id/pulse_ring_2"
            android:layout_width="185dp"
            android:layout_height="185dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="191dp"
            android:background="@drawable/bg_pulse_ring"
            android:alpha="0" />

        <!-- Pulse ring 3 (outermost) -->
        <View
            android:id="@+id/pulse_ring_3"
            android:layout_width="230dp"
            android:layout_height="230dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="169dp"
            android:background="@drawable/bg_pulse_ring"
            android:alpha="0" />

        <!-- LvovFlow: Connection timer label -->
        <TextView
            android:id="@+id/conn_timer_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="120dp"
            android:text="Время подключения"
            android:textColor="?whiteOrTextPrimary"
            android:textSize="12sp"
            android:alpha="0.6"
            android:visibility="gone" />

        <!-- LvovFlow: Connection timer clock -->
        <TextView
            android:id="@+id/conn_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="138dp"
            android:text="00:00:00"
            android:textColor="?whiteOrTextPrimary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:visibility="gone" />

        <!-- FAB (connect button) -->
        <io.nekohasekai.sagernet.widget.ServiceButton
            android:id="@+id/fab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:elevation="12dp"
            android:nextFocusDown="@+id/stats"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="228dp"
            app:backgroundTint="?fabColorBackground"
            app:fabCustomSize="112dp"
            app:iconSize="84dp"
            app:pressedTranslationZ="6dp"
            app:srcCompat="@drawable/ic_service_idle" />

        <!-- Status text -->
        <TextView
            android:id="@+id/conn_status_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="352dp"
            android:text="Активировать ускорение"
            android:textColor="?whiteOrTextPrimary"
            android:textSize="15sp"
            android:alpha="0.85" />

        <!-- Server name label (shown only when connected) -->
        <TextView
            android:id="@+id/conn_server_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="376dp"
            android:text=""
            android:textColor="#25C9EF"
            android:textSize="12sp"
            android:alpha="0.9"
            android:visibility="gone" />

        <!-- Server info card (flag, name, ping — shown when connected) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/server_info_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_marginTop="408dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:visibility="gone"
            app:cardBackgroundColor="#0F1E38"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/server_flag_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌐 LvovFlow"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/server_status_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Соединение защищено 🔒"
                        android:textColor="#25C9EF"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/server_ping"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#25C9EF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="пинг"
                        android:textColor="#55FFFFFF"
                        android:textSize="10sp" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Speed row (upload / download — shown when connected) -->
        <LinearLayout
            android:id="@+id/speed_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_marginTop="510dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#0B25C9EF"
                android:padding="14dp">

                <TextView
                    android:id="@+id/speed_up"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 B/s"
                    android:textColor="#25C9EF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↑ Исходящий"
                    android:textColor="#55FFFFFF"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="40dp"
                android:layout_gravity="center_vertical"
                android:background="#25FFFFFF" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#0B25C9EF"
                android:padding="14dp">

                <TextView
                    android:id="@+id/speed_down"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 B/s"
                    android:textColor="#25C9EF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↓ Входящий"
                    android:textColor="#55FFFFFF"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- StatsBar (bottom) - hidden, speed shown in custom speed_row -->
        <io.nekohasekai.sagernet.widget.StatsBar
            android:id="@+id/stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginBottom="56dp"
            android:visibility="gone"
            android:nextFocusUp="@+id/fab"
            app:backgroundTint="?colorMaterial300"
            app:contentInsetStart="0dp"
            app:hideOnScroll="true"
            app:layout_scrollFlags="enterAlways|scroll">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <io.nekohasekai.sagernet.widget.SpeedGraphView
                        android:id="@+id/speed_graph"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:id="@+id/tx"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="marquee"
                            android:singleLine="true"
                            android:textColor="?whiteOrTextPrimary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/rx"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="marquee"
                            android:singleLine="true"
                            android:textColor="?whiteOrTextPrimary"
                            android:textSize="12sp" />

                    </LinearLayout>

                </LinearLayout>

                <TextView
                    android:id="@+id/status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="fill_horizontal"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="?whiteOrTextPrimary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="@string/connection_test_available" />

            </LinearLayout>

        </io.nekohasekai.sagernet.widget.StatsBar>

        <!-- Bottom Navigation Bar -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:elevation="16dp"
            android:paddingBottom="4dp"
            app:backgroundTint="#0D1626"
            app:itemIconTint="@color/bottom_nav_icon"
            app:itemTextColor="@color/bottom_nav_icon"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/bottom_nav_menu" />


    </androidx.coordinatorlayout.widget.CoordinatorLayout>


    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        style="@style/Widget.Design.NavigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/layout_nav_header"
        app:itemIconTint="@color/navigation_icon"
        app:itemTextColor="@color/navigation_icon"
        app:menu="@menu/main_drawer_menu" />

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view_black"
        style="@style/Widget.Design.NavigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/layout_nav_header"
        app:itemIconTint="@color/navigation_icon"
        app:itemShapeAppearance="@style/ShapeAppearance.MaterialComponents.MediumComponent"
        app:itemShapeFillColor="@color/navigation_item"
        app:itemTextColor="@color/navigation_icon"
        app:menu="@menu/main_drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>