<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Profile list — hidden in monolithic LvovFlow mode (servers are auto-managed) -->
    <com.simplecityapps.recyclerview_fastscroll.views.FastScrollRecyclerView
        android:id="@+id/configuration_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingLeft="4dp"
        android:paddingTop="225dp"
        android:paddingRight="4dp"
        android:paddingBottom="64dp"
        android:scrollbarSize="0dp"
        android:visibility="gone"
        app:fastScrollAutoHide="true"
        app:fastScrollThumbColor="?colorPrimary"
        app:fastScrollThumbInactiveColor="?colorPrimary"
        tools:listitem="@layout/layout_profile" />

    <!-- LvovFlow: Clean loading/retry state (replaces ugly NekoBox empty state) -->
    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <!-- Spinner (shown during auto-import) -->
        <ProgressBar
            android:id="@+id/empty_state_progress"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="#25C9EF"
            android:visibility="visible" />

        <TextView
            android:id="@+id/empty_state_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Обновление серверов…"
            android:textColor="#E2E8F0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/empty_state_subtitle"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Загружаем список серверов. Это займёт несколько секунд."
            android:textColor="#64748B"
            android:textSize="14sp"
            android:textAlignment="center"
            android:lineSpacingExtra="2dp" />

        <!-- Retry button (hidden by default, shown on failure) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_retry_import"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Повторить"
            android:textColor="#25C9EF"
            android:visibility="gone"
            app:strokeColor="#25C9EF"
            app:cornerRadius="12dp" />

    </LinearLayout>

</FrameLayout>