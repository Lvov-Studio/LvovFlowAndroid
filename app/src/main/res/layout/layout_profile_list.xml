<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Profile list -->
    <com.simplecityapps.recyclerview_fastscroll.views.FastScrollRecyclerView
        android:id="@+id/configuration_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingLeft="4dp"
        android:paddingTop="225dp"
        android:paddingRight="4dp"
        android:paddingBottom="64dp"
        android:scrollbarSize="0dp"
        app:fastScrollAutoHide="true"
        app:fastScrollThumbColor="?colorPrimary"
        app:fastScrollThumbInactiveColor="?colorPrimary"
        tools:listitem="@layout/layout_profile" />

    <!-- LvovFlow Empty State -->
    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_service_busy"
            android:alpha="0.3"
            android:contentDescription="LvovFlow" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="LvovFlow"
            android:textColor="#25C9EF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Добавьте сервер для начала работы"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="15sp"
            android:textAlignment="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Нажмите + в правом верхнем углу"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="13sp"
            android:textAlignment="center"
            android:alpha="0.7" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_paste_clipboard"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="📋  Вставить из буфера обмена"
            android:textColor="#25C9EF"
            app:strokeColor="#25C9EF" />

    </LinearLayout>

</FrameLayout>