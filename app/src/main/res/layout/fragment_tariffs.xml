<?xml version="1.0" encoding="utf-8"?>
<!-- LvovFlow: Native Tariffs Screen — Concept Design -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lf_bg_dark"
    android:fitsSystemWindows="true"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:paddingBottom="100dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="24dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- ══════ Header ══════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Тарифы"
            android:textColor="@color/lf_text_main"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Безлимитный трафик на максимальной скорости"
            android:textColor="@color/lf_text_muted"
            android:textSize="14sp" />

        <!-- ══════════════════════════════════════════════ -->
        <!-- CARD: Flow (POPULAR) — full featured           -->
        <!-- ══════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/card_flow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:background="@drawable/bg_tariff_card_popular"
            android:padding="20dp">

            <!-- Title row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Flow"
                    android:textColor="@color/lf_text_main"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_flow_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="99 ₽"
                    android:textColor="@color/lf_text_main"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="/мес"
                    android:textColor="@color/lf_text_muted"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Для повседневного интернета"
                android:textColor="@color/lf_text_muted"
                android:textSize="13sp" />

            <!-- Popular badge -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_badge_popular"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="✓ ПОПУЛЯРНЫЙ"
                android:textColor="@color/lf_secondary_mint"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <!-- Features -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp">

                <!-- Feature 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_tariff_bolt"
                        app:tint="@color/lf_secondary_mint" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Безлимитное ускорение"
                        android:textColor="@color/lf_text_main"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Feature 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_tariff_shield"
                        app:tint="@color/lf_secondary_mint" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Блокировка рекламы"
                        android:textColor="@color/lf_text_main"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Feature 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_tariff_devices"
                        app:tint="@color/lf_secondary_mint" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="До 5 устройств"
                        android:textColor="@color/lf_text_main"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Per day price -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="~3 ₽/день"
                android:textColor="@color/lf_text_muted"
                android:textSize="12sp" />

            <!-- CTA Button -->
            <TextView
                android:id="@+id/btn_flow_buy"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_checkout_btn"
                android:gravity="center"
                android:text="Оформить"
                android:textColor="@color/lf_text_main"
                android:textSize="16sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- ══════════════════════════════════════════════ -->
        <!-- CARD: Flow Pro (COMING SOON)                   -->
        <!-- ══════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/card_flow_pro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:background="@drawable/bg_concept_card"
            android:padding="20dp"
            android:alpha="0.5">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Flow Pro"
                    android:textColor="@color/lf_text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="149 ₽"
                    android:textColor="@color/lf_text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="/мес"
                    android:textColor="@color/lf_text_muted"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_badge_soon"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:text="Скоро"
                    android:textColor="@color/lf_primary_cyan"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Для требовательных пользователей"
                android:textColor="@color/lf_text_muted"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- ══════════════════════════════════════════════ -->
        <!-- CARD: Flow Ultimate (COMING SOON)              -->
        <!-- ══════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/card_flow_ultimate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:background="@drawable/bg_concept_card"
            android:padding="20dp"
            android:alpha="0.5">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Flow Ultimate"
                    android:textColor="@color/lf_text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="299 ₽"
                    android:textColor="@color/lf_text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="/мес"
                    android:textColor="@color/lf_text_muted"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_badge_soon"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:text="Скоро"
                    android:textColor="@color/lf_primary_cyan"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Максимум возможностей"
                android:textColor="@color/lf_text_muted"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
