<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_activation_gradient"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:id="@+id/activation_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal"
        android:minHeight="700dp">

        <!-- Top spacer -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:minHeight="40dp" />

        <!-- Glow + Logo container -->
        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp">

            <!-- Glow background -->
            <View
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:background="@drawable/bg_glow_circle"
                android:layout_gravity="center" />

            <!-- Lion paw icon -->
            <ImageView
                android:id="@+id/logo_icon"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_service_busy"
                android:tint="#25C9EF" />
        </FrameLayout>

        <!-- App Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="LvovFlow"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            android:fontFamily="sans-serif-medium" />

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="48dp"
            android:text="Акселератор интернета"
            android:textColor="#7099C0"
            android:textSize="14sp"
            android:letterSpacing="0.08"
            android:textAllCaps="false" />

        <!-- =================== STEP 1: Email =================== -->
        <LinearLayout
            android:id="@+id/step_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="Введите ваш email"
                android:textColor="#FFFFFFCC"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <!-- Email field -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_field"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✉"
                    android:textColor="#25C9EF"
                    android:textSize="18sp"
                    android:layout_marginEnd="12dp" />

                <EditText
                    android:id="@+id/email_input"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="you@example.com"
                    android:hintTextColor="#50FFFFFF"
                    android:inputType="textEmailAddress"
                    android:imeOptions="actionDone"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:singleLine="true" />
            </LinearLayout>

            <!-- Send code button -->
            <Button
                android:id="@+id/btn_send_code"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_button_cyan"
                android:text="Получить код"
                android:textColor="#0A1628"
                android:textSize="16sp"
                android:textStyle="bold"
                android:elevation="4dp" />

            <!-- Progress indicator row -->
            <LinearLayout
                android:id="@+id/email_progress_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                android:orientation="horizontal">

                <ProgressBar
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:indeterminateTint="#25C9EF"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Отправляем код..."
                    android:textColor="#7099C0"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- =================== STEP 2: OTP =================== -->
        <LinearLayout
            android:id="@+id/step_otp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Back arrow + title -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/btn_back_to_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="← "
                    android:textColor="#25C9EF"
                    android:textSize="22sp"
                    android:padding="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Введите код из письма"
                    android:textColor="#FFFFFFCC"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Hint -->
            <TextView
                android:id="@+id/otp_hint_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:text="Код отправлен на you@example.com"
                android:textColor="#7099C0"
                android:textSize="13sp"
                android:gravity="center" />

            <!-- OTP 6-digit input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_field"
                android:orientation="horizontal"
                android:gravity="center">

                <EditText
                    android:id="@+id/otp_input"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="— — — — — —"
                    android:hintTextColor="#30FFFFFF"
                    android:inputType="numberPassword"
                    android:imeOptions="actionDone"
                    android:textColor="#25C9EF"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.35"
                    android:gravity="center"
                    android:maxLength="6"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Verify button -->
            <Button
                android:id="@+id/btn_verify"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_button_cyan"
                android:text="Войти"
                android:textColor="#0A1628"
                android:textSize="16sp"
                android:textStyle="bold"
                android:elevation="4dp" />

            <!-- Resend row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Не пришло письмо? "
                    android:textColor="#50FFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/btn_resend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Отправить ещё раз"
                    android:textColor="#25C9EF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Verify progress -->
            <LinearLayout
                android:id="@+id/verify_progress_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                android:orientation="horizontal">

                <ProgressBar
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:indeterminateTint="#25C9EF"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Проверяем код..."
                    android:textColor="#7099C0"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Error label (shared) -->
        <TextView
            android:id="@+id/error_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#22FF4444"
            android:paddingVertical="10dp"
            android:paddingHorizontal="16dp"
            android:text=""
            android:textColor="#FF6B6B"
            android:textSize="13sp"
            android:gravity="center"
            android:visibility="gone" />

        <!-- Bottom spacer -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:minHeight="24dp" />

        <!-- Footer -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Нет аккаунта? lvovflow.com"
            android:textColor="#30FFFFFF"
            android:textSize="12sp"
            android:gravity="center" />

    </LinearLayout>

</ScrollView>
