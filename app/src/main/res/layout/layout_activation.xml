<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_activation_gradient"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:id="@+id/activation_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp"
        android:gravity="center_horizontal">

        <!-- Top spacer -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="40dp" />

        <!-- Glow + Logo container -->
        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp">

            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:background="@drawable/bg_glow_circle"
                android:layout_gravity="center" />

            <ImageView
                android:id="@+id/logo_icon"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_gravity="center"
                android:src="@mipmap/ic_launcher" />

        </FrameLayout>

        <!-- App Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="LvovFlow"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            android:fontFamily="sans-serif-medium" />

        <!-- Subtitle: Вход в личный кабинет -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Вход в личный кабинет"
            android:textColor="#7099C0"
            android:textSize="13sp" />

        <!-- Trial badge: 7 дней бесплатно -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            android:background="@drawable/bg_badge_trial"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="★  7 дней бесплатно"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- =================== Login card =================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_dark"
            android:orientation="vertical"
            android:padding="20dp">


            <!-- =================== STEP 1: Email =================== -->
            <LinearLayout
                android:id="@+id/step_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Введите email — пришлём 6-значный код."
                    android:textColor="#7099C0"
                    android:textSize="13sp"
                    android:gravity="center" />

                <!-- Email field -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_input_field"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <EditText
                        android:id="@+id/email_input"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Ваш Email"
                        android:textColorHint="#40FFFFFF"
                        android:inputType="textEmailAddress"
                        android:imeOptions="actionDone"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:singleLine="true" />
                </LinearLayout>

                <!-- Send code button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_send_code"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Получить код →"
                    android:textColor="#0A1628"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="#25C9EF"
                    app:cornerRadius="12dp"
                    android:elevation="4dp" />

                <!-- Progress indicator row -->
                <LinearLayout
                    android:id="@+id/email_progress_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:layout_marginTop="14dp"
                    android:visibility="gone"
                    android:orientation="horizontal">

                    <ProgressBar
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:indeterminateTint="#25C9EF"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Отправляем код..."
                        android:textColor="#7099C0"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- =================== STEP 2: OTP =================== -->
            <LinearLayout
                android:id="@+id/step_otp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/btn_back_to_email"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="← "
                        android:textColor="#25C9EF"
                        android:textSize="22sp"
                        android:padding="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Введите код из письма"
                        android:textColor="#FFFFFFCC"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <TextView
                    android:id="@+id/otp_hint_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Код отправлен на you@example.com"
                    android:textColor="#7099C0"
                    android:textSize="12sp"
                    android:gravity="center" />

                <!-- OTP 6-digit input -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="68dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_input_field"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <EditText
                        android:id="@+id/otp_input"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="— — — — — —"
                        android:textColorHint="#30FFFFFF"
                        android:inputType="numberPassword"
                        android:imeOptions="actionDone"
                        android:textColor="#25C9EF"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.35"
                        android:gravity="center"
                        android:maxLength="6"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_verify"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Войти →"
                    android:textColor="#0A1628"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="#25C9EF"
                    app:cornerRadius="12dp"
                    android:elevation="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Не пришло письмо? "
                        android:textColor="#50FFFFFF"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/btn_resend"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Отправить ещё раз"
                        android:textColor="#25C9EF"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/verify_progress_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:layout_marginTop="14dp"
                    android:visibility="gone"
                    android:orientation="horizontal">

                    <ProgressBar
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:indeterminateTint="#25C9EF"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Проверяем код..."
                        android:textColor="#7099C0"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
        <!-- end login card -->

        <!-- Error label (shared) -->
        <TextView
            android:id="@+id/error_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#22FF4444"
            android:paddingVertical="10dp"
            android:paddingHorizontal="16dp"
            android:text=""
            android:textColor="#FF6B6B"
            android:textSize="13sp"
            android:gravity="center"
            android:visibility="gone" />

        <!-- =================== ПОЧЕМУ ВЫБИРАЮТ НАС =================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="14dp"
            android:text="ПОЧЕМУ ВЫБИРАЮТ НАС"
            android:textColor="#40FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:textAllCaps="false"
            android:gravity="center" />

        <!-- Stats row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <!-- 10G Speed -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡"
                    android:textSize="20sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10G"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="СКОРОСТЬ"
                    android:textColor="#50FFFFFF"
                    android:textSize="9sp"
                    android:letterSpacing="0.08" />
            </LinearLayout>

            <!-- 0 logs -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛡"
                    android:textSize="20sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 лог"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="АНОНИМНО"
                    android:textColor="#50FFFFFF"
                    android:textSize="9sp"
                    android:letterSpacing="0.08" />
            </LinearLayout>

            <!-- 24ms ping -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱"
                    android:textSize="20sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24ms"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ПИНГ"
                    android:textColor="#50FFFFFF"
                    android:textSize="9sp"
                    android:letterSpacing="0.08" />
            </LinearLayout>

            <!-- 99.9% uptime -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📈"
                    android:textSize="20sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="99.9%"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UPTIME"
                    android:textColor="#50FFFFFF"
                    android:textSize="9sp"
                    android:letterSpacing="0.08" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
