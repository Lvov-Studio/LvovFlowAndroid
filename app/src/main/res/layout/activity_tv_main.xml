<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1628">

    <!-- Safe area with TV overscan margins -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="48dp"
        android:paddingEnd="48dp"
        android:paddingTop="27dp"
        android:paddingBottom="27dp">

        <!-- ===== TOP BAR ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <!-- Logo -->
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@mipmap/ic_launcher"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LvovFlow"
                android:textColor="#F8FAFC"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <!-- Subscription badge -->
            <TextView
                android:id="@+id/tv_sub_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_badge"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="● Активна"
                android:textColor="#22C55E"
                android:textSize="13sp"
                android:layout_marginEnd="16dp" />

            <!-- Version -->
            <TextView
                android:id="@+id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#64748B"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- ===== MAIN CONTENT: LEFT + RIGHT ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- ===== LEFT PANEL: Connect ===== -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="4"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="32dp">

                <!-- Status text above button -->
                <TextView
                    android:id="@+id/tv_status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:text="Активировать ускорение"
                    android:textColor="#E2E8F0"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- Big Connect Button -->
                <FrameLayout
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_marginBottom="16dp">

                    <!-- Glow background -->
                    <View
                        android:id="@+id/tv_glow"
                        android:layout_width="180dp"
                        android:layout_height="180dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_glow_circle"
                        android:alpha="0.4" />

                    <!-- The button itself -->
                    <Button
                        android:id="@+id/tv_btn_connect"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_tv_connect_button"
                        android:text="⚡"
                        android:textSize="48sp"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:nextFocusDown="@+id/tv_btn_subscription"
                        android:nextFocusRight="@+id/tv_btn_subscription" />
                </FrameLayout>

                <!-- Timer -->
                <TextView
                    android:id="@+id/tv_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00:00"
                    android:textColor="#F8FAFC"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp" />

                <!-- Speed row -->
                <LinearLayout
                    android:id="@+id/tv_speed_row"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_speed_down"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="↓ 0 Б/с"
                        android:textColor="#22C55E"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="20dp"
                        android:layout_marginEnd="20dp"
                        android:background="#2E3A50" />

                    <TextView
                        android:id="@+id/tv_speed_up"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="↑ 0 Б/с"
                        android:textColor="#22D3EE"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- IP info -->
                <TextView
                    android:id="@+id/tv_ip_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#64748B"
                    android:textSize="14sp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- ===== RIGHT PANEL: Info + Actions ===== -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="3"
                android:orientation="vertical"
                android:gravity="center_vertical">

                <!-- Stats cards row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <!-- Speed card -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_stat_card"
                        android:padding="16dp"
                        android:layout_marginEnd="8dp">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_stat_speed"
                            android:layout_marginBottom="8dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10G"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="СКОРОСТЬ"
                            android:textColor="#55FFFFFF"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Ping card -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_stat_card"
                        android:padding="16dp"
                        android:layout_marginEnd="8dp">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_stat_ping"
                            android:layout_marginBottom="8dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="24ms"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ПИНГ"
                            android:textColor="#55FFFFFF"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Shield card -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_stat_card"
                        android:padding="16dp">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_stat_shield"
                            android:layout_marginBottom="8dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 лог"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="АНОНИМНО"
                            android:textColor="#55FFFFFF"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Action buttons -->
                <Button
                    android:id="@+id/tv_btn_subscription"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_tv_button_focus"
                    android:text="💳  Моя подписка"
                    android:textColor="#E2E8F0"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    android:gravity="center"
                    android:focusable="true"
                    android:nextFocusUp="@id/tv_btn_connect"
                    android:nextFocusDown="@+id/tv_btn_about"
                    android:nextFocusLeft="@id/tv_btn_connect" />

                <Button
                    android:id="@+id/tv_btn_about"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_tv_button_focus"
                    android:text="ℹ️  О приложении"
                    android:textColor="#E2E8F0"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    android:gravity="center"
                    android:focusable="true"
                    android:nextFocusUp="@id/tv_btn_subscription"
                    android:nextFocusDown="@+id/tv_btn_logout"
                    android:nextFocusLeft="@id/tv_btn_connect" />

                <Button
                    android:id="@+id/tv_btn_logout"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_tv_button_focus"
                    android:text="🚪  Выйти"
                    android:textColor="#94A3B8"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    android:gravity="center"
                    android:focusable="true"
                    android:nextFocusUp="@id/tv_btn_about"
                    android:nextFocusLeft="@id/tv_btn_connect" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</FrameLayout>
