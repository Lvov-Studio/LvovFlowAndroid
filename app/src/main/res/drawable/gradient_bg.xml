<?xml version="1.0" encoding="utf-8"?>
<!--
  LvovFlow concept background:
  Solid #0B0E14 base with subtle green radial glow
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Solid dark base -->
    <item>
        <shape>
            <solid android:color="#0B0E14" />
        </shape>
    </item>

    <!-- Subtle green radial glow near center top -->
    <item>
        <shape>
            <gradient
                android:type="radial"
                android:gradientRadius="300%"
                android:startColor="#0800E676"
                android:endColor="#00000000"
                android:centerX="0.5"
                android:centerY="0.30" />
        </shape>
    </item>

</layer-list>
