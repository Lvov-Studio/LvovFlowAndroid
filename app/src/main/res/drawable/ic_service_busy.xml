        <path android:fillColor="#FFFFFF"
            android:pathData="M6.8,5.8 A2.2,2.2 0 1 0 11.2,5.8 A2.2,2.2 0 1 0 6.8,5.8 Z"/>
        <!-- Center-right toe -->
        <path android:fillColor="#FFFFFF"
            android:pathData="M12.8,5.8 A2.2,2.2 0 1 0 17.2,5.8 A2.2,2.2 0 1 0 12.8,5.8 Z"/>
        <!-- Top-right toe -->
        <path android:fillColor="#FFFFFF"
            android:pathData="M16.5,9.5 A2.5,2.5 0 1 0 21.5,9.5 A2.5,2.5 0 1 0 16.5,9.5 Z"/>

