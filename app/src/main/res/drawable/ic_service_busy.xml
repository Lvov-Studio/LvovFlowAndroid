<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
        android:width="36dp"
        android:height="36dp"
        android:viewportWidth="24"
        android:viewportHeight="24">

    <!--
      LvovFlow Paw Print - connected/busy state (full white).
      All paths wrapped in named group so animated-vector can target
      it with scale animation instead of path morphing.
    -->
    <group
        android:name="paw_group"
        android:pivotX="12"
        android:pivotY="12">

        <!-- Central pad -->
        <path android:fillColor="#FFFFFF"
            android:pathData="M8,15.5 A4,3 0 1 0 16,15.5 A4,3 0 1 0 8,15.5 Z"/>
        <!-- Top-left toe -->
        <path android:fillColor="#FFFFFF"
            android:pathData="M4,10 A2,2 0 1 0 8,10 A2,2 0 1 0 4,10 Z"/>
        <!-- Center-left toe -->
        <path android:fillColor="#FFFFFF"
            android:pathData="M7.7,7.5 A1.8,1.8 0 1 0 11.3,7.5 A1.8,1.8 0 1 0 7.7,7.5 Z"/>
        <!-- Center-right toe -->
        <path android:fillColor="#FFFFFF"
            android:pathData="M12.7,7.5 A1.8,1.8 0 1 0 16.3,7.5 A1.8,1.8 0 1 0 12.7,7.5 Z"/>
        <!-- Top-right toe -->
        <path android:fillColor="#FFFFFF"
            android:pathData="M16,10 A2,2 0 1 0 20,10 A2,2 0 1 0 16,10 Z"/>

    </group>

</vector>
