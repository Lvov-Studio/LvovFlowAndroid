        android:viewportWidth="24"
        android:viewportHeight="24">

    <!--
      LvovFlow Paw Print — CONNECTED/busy state.
      Full white (#FFFFFF). Same enlarged paths as idle.
      Wrapped in named group for scale animation in ic_service_connected/stopping.
